---
---

<section id="visites" class="visits-section reveal">
	<div class="visits-content">
		<div class="visits-header">
			<div class="visits-icon-badge" aria-hidden="true">
				<svg
					class="visits-icon"
					width="28"
					height="28"
					viewBox="0 0 24 24"
					fill="none"
					xmlns="http://www.w3.org/2000/svg"
				>
					<!-- Calendrier + horloge (prise de rendez-vous) -->
					<rect x="3" y="5" width="15" height="14" rx="2" ry="2" stroke="#ffffff" stroke-width="2" />
					<path d="M8 3v4M13 3v4" stroke="#ffffff" stroke-width="2" stroke-linecap="round" />
					<path d="M3 11h15" stroke="#ffffff" stroke-width="2" />
					<circle cx="17.5" cy="16.5" r="4.25" stroke="#ffffff" stroke-width="2" />
					<path d="M17.5 14.75V17l1.25 1" stroke="#ffffff" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" />
				</svg>
			</div>
			<h3>Gestion des visites</h3>
		</div>
		<div class="visits-text">
			<div class="visit-item">
				<svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<polyline points="20 6 9 17 4 12"/>
				</svg>
				<p>
					Une description précise de votre profil (situation actuelle, niveau d'études ou projet artistique, durée de location envisagée) permettra d'organiser rapidement un rendez-vous adapté.
				</p>
			</div>
			<div class="visit-item">
				<svg class="check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
					<polyline points="20 6 9 17 4 12"/>
				</svg>
				<p>
					En cas d'éloignement géographique justifié, une visite en visioconférence pourra également être proposée dans les meilleurs délais.
				</p>
			</div>
		</div>
	</div>
</section>

<style>
	.visits-section {
		margin: 3rem 0;
		padding: 0;
		background: linear-gradient(135deg, #f0abfc 0%, #a78bfa 40%, #38bdf8 100%);
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 8px 32px rgba(168, 85, 247, 0.22);
	}

	.visits-content {
		max-width: 900px;
		margin: 0 auto;
		padding: 2.5rem;
		background: linear-gradient(180deg, #ffffff 0%, #fdf4ff 100%);
		margin: 2rem;
		border-radius: 14px;
		border: 1px solid rgba(192, 132, 252, 0.35);
		box-shadow: 0 4px 20px rgba(126, 34, 206, 0.08);
	}

	.visits-header {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		margin-bottom: 2rem;
		padding-bottom: 1rem;
		border-bottom: 2px solid #e0e7ff;
	}

	.visits-icon-badge {
		flex-shrink: 0;
		width: 52px;
		height: 52px;
		border-radius: 50%;
		background: linear-gradient(145deg, #d946ef 0%, #9333ea 38%, #6366f1 100%);
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow:
			0 6px 22px rgba(147, 51, 234, 0.45),
			inset 0 1px 0 rgba(255, 255, 255, 0.28);
	}

	.visits-icon {
		flex-shrink: 0;
		display: block;
	}

	.visits-content h3 {
		font-size: 1.5rem;
		margin: 0;
		color: #1a1a1a;
		font-weight: 600;
	}

	.visits-text {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.visit-item {
		display: flex;
		align-items: flex-start;
		gap: 1rem;
		padding: 1rem;
		background: linear-gradient(90deg, #faf5ff 0%, #ffffff 55%);
		border-radius: 10px;
		border-left: 4px solid #a855f7;
		transition:
			transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
			background 0.35s ease,
			box-shadow 0.35s ease;
	}

	.visit-item:hover {
		background: linear-gradient(90deg, #f3e8ff 0%, #fdf4ff 100%);
		transform: translateX(10px) scale(1.01);
		box-shadow: 0 8px 24px rgba(168, 85, 247, 0.18);
	}

	.visit-bullet {
		color: #8b5cf6;
		flex-shrink: 0;
		margin-top: 0.25rem;
	}

	.visit-item p {
		font-size: 1.05rem;
		line-height: 1.7;
		margin: 0;
		color: #4a5568;
		flex: 1;
	}

	@media (max-width: 768px) {
		.visits-content {
			padding: 1.5rem;
			margin: 1rem;
		}

		.visits-header {
			margin-bottom: 1.5rem;
		}

		.visits-content h3 {
			font-size: 1.25rem;
		}

		.visit-item {
			padding: 0.875rem;
		}

		.visit-item p {
			font-size: 0.95rem;
		}

		.visit-bullet {
			width: 16px;
			height: 16px;
		}

		.visits-icon-badge {
			width: 46px;
			height: 46px;
			border-radius: 50%;
		}

		.visits-icon {
			width: 24px;
			height: 24px;
		}
	}
</style>

