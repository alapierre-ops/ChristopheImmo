---
import Layout from '../layouts/Layout.astro';
import propertiesData from '../data/properties.json';
import IntroSection from '../components/IntroSection.astro';
import InfoSection from '../components/InfoSection.astro';
import VisitsSection from '../components/VisitsSection.astro';
import { processProperties, type Property } from '../utils/properties';
import '../styles/index.css';

const properties: Property[] = await processProperties(propertiesData);
---

<Layout title="Propriétés à louer">
	<main>
		<header id="accueil" class="header">
			<div class="container header__layout reveal">
				<div class="header__brand">
					<a href="/" class="header__brand-link" aria-label="Christophe Immobilier — accueil">
						<img
							src="/logo-christophe-immobilier.png"
							alt=""
							width="500"
							height="500"
							decoding="async"
						/>
					</a>
				</div>
				<div class="header__intro">
					<h1>Découvrez mes logements</h1>
					<p class="subtitle">Pour étudiants et artistes</p>
				</div>
			</div>
		</header>

		<div class="container">
			<IntroSection />

			<section id="biens" class="properties-section">
				<div class="section-header reveal">
					<h2>Mes biens disponibles</h2>
					<p>Consultez mon offre de propriétés à louer</p>
				</div>

				<div class="properties-grid reveal-stagger">
					{properties.map((property, index) => (
						<article
							class="property-card reveal-stagger-item"
							style={`--stagger: ${index}`}
							data-property-id={property.id}
							data-property-title={property.title}
						>
							<a
								href={`/bien/${property.id}`}
								class="property-card__overlay"
								aria-label={`Voir la fiche : ${property.title}`}
							>
								<span class="property-card__overlay-sr">Voir la fiche</span>
							</a>
							<div class="property-card__inner">
							<div class="property-badge">Disponible</div>
							<div class="property-image">
								{property.images && property.images.length > 0 ? (
									<>
										<img src={property.images[0]} alt={property.title} />
										{property.images.length > 1 && (
											<div class="image-count">
												<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
													<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
													<circle cx="8.5" cy="8.5" r="1.5"/>
													<polyline points="21 15 16 10 5 21"/>
												</svg>
												{property.images.length} photos
											</div>
										)}
									</>
								) : (
									<div class="placeholder-image">Pas d'image</div>
								)}
							</div>
							<div class="property-content">
								<h2 class="property-title">{property.title}</h2>
								<p class="property-address">
									<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
										<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
										<circle cx="12" cy="10" r="3"/>
									</svg>
									{property.address}
								</p>
								{property.coordinates && (
									<a
										href={`/bien/${property.id}#localisation`}
										class="property-map-link"
									>
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
											<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
											<circle cx="12" cy="10" r="3"/>
										</svg>
										Voir sur la carte
									</a>
								)}
								<p class="property-description">{property.shortDescription}</p>
								<div class="property-details">
									<span class="detail-item">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
											<line x1="9" y1="3" x2="9" y2="21"/>
											<line x1="3" y1="9" x2="21" y2="9"/>
										</svg>
										{property.surface} m²
									</span>
									<span class="detail-item">
										<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
											<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
											<polyline points="9 22 9 12 15 12 15 22"/>
										</svg>
										{property.rooms} pièce{property.rooms > 1 ? 's' : ''}
									</span>
								</div>
								{property.features && property.features.length > 0 && (
									<div class="property-features">
										{property.features
											.slice(0, property.id === '7' || property.id === '1'|| property.id === '2' ? 5 : 4)
											.map((feature) => (
												<span class="feature-tag">{feature}</span>
											))}
									</div>
								)}
								<div class="property-price">
									{property.isColocation ? (
										<>
											<span class="colocation-badge-small">Colocation</span>
											<span class="price-main">{property.colocationPrice || property.price} €/mois</span>
											<span class="price-per-person">par personne</span>
										</>
									) : (
										<>
											{property.price} €/mois
										</>
									)}
									{property.priceNote && (
										<span class="water-included">{property.priceNote}</span>
									)}
								</div>
							</div>
							</div>
						</article>
					))}
				</div>
			</section>

			<InfoSection />
			<VisitsSection />
		</div>

		<footer id="contact" class="footer reveal">
			<div class="container">
				<div class="footer-content">
					<div class="footer-section">
						<h2 class="footer-contact-title">Contact</h2>
						<h3>Pour toute demande d'information ou disponibilité, n'hésitez pas à me solliciter.</h3>
						<p class="footer-contact-line">
							<svg class="footer-contact-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
								<polyline points="22,6 12,13 2,6"/>
							</svg>
							<a href="mailto:christophe-lapierre@orange.fr">christophe-lapierre@orange.fr</a>
						</p>
						<p class="footer-contact-line">
							<svg class="footer-contact-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
							</svg>
							<a href="tel:+33601767543">+33 6 01 76 75 43</a>
						</p>
						<p class="footer-contact-line">
							<svg class="footer-contact-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
								<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
								<polyline points="14 2 14 8 20 8"/>
								<line x1="16" y1="13" x2="8" y2="13"/>
								<line x1="16" y1="17" x2="8" y2="17"/>
								<line x1="10" y1="9" x2="8" y2="9"/>
							</svg>
							<span>SIREN 850&nbsp;665&nbsp;159</span>
						</p>
					</div>
				</div>
				<div class="footer-bottom">
					<h3>Copyright &copy; Christophe Immobilier - Tous droits réservés - {new Date().getFullYear()}</h3>
				</div>
			</div>
		</footer>
	</main>
</Layout>

<script>
	import { events } from '../utils/posthog';
	
	events.pageView('home');
	
	document.addEventListener('DOMContentLoaded', () => {
		document.querySelectorAll('.property-card__overlay').forEach((link) => {
			link.addEventListener('click', () => {
				const card = link.closest('.property-card');
				const propertyId = card?.getAttribute('data-property-id');
				const propertyTitle = card?.getAttribute('data-property-title');
				if (propertyId && propertyTitle) {
					events.propertyCardClicked(propertyId, propertyTitle);
				}
			});
		});
	});
</script>